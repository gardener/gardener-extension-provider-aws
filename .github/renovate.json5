{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended', // https://docs.renovatebot.com/presets-config/#configrecommended
    ':semanticCommitsDisabled', // Disable "chore(deps): " prefixes in PR titles
    'github>gardener/ci-infra//config/renovate/automerge-with-tide.json5',
  ],
  labels: [
    'area/compliance',
    'kind/enhancement',
  ],
  postUpdateOptions: [
    'gomodTidy',
  ],
  prFooter: '**Release note**:\n```other dependency\nNONE\n```',
  rebaseWhen: 'conflicted',
  dependencyDashboard: false,
  packageRules: [
    // github-actions: auto-merge all updates
    {
      matchManagers: ['github-actions'],
      automerge: true,
    },
    // gomod: non-gardener, non-aws
    {
      matchManagers: ['gomod'],
      matchPackageNames: [
        '!github.com/gardener/**',
        '!github.com/aws/**',
        '!k8s.io/**',
        '!sigs.k8s.io/**',
        '!github.com/gardener/etcd-druid/**',
        '!github.com/prometheus-operator/**',
      ],
      groupName: 'non-gardener-dependencies',
      matchUpdateTypes: ['minor', 'patch', 'digest'],
      automerge: true,
      prTitle: 'Update non-gardener-dependencies',
    },
    {
      matchManagers: ['gomod'],
      matchPackageNames: [
        '!github.com/gardener/**',
        '!github.com/aws/**',
        '!k8s.io/**',
        '!sigs.k8s.io/**',
        '!github.com/gardener/etcd-druid/**',
        '!github.com/prometheus-operator/**',
      ],
      groupName: 'non-gardener-dependencies',
      matchUpdateTypes: ['major'],
      prTitle: 'Update non-gardener-dependencies',
    },
    // gomod: aws provider SDK
    {
      matchManagers: ['gomod'],
      matchPackageNames: ['github.com/aws/**'],
      groupName: 'provider-sdk-dependencies',
      matchUpdateTypes: ['minor', 'patch', 'digest'],
      automerge: true,
      prTitle: 'Update provider-sdk-dependencies',
    },
    {
      matchManagers: ['gomod'],
      matchPackageNames: ['github.com/aws/**'],
      groupName: 'provider-sdk-dependencies',
      matchUpdateTypes: ['major'],
      prTitle: 'Update provider-sdk-dependencies',
    },
    // gomod: gardener dependencies — manual only
    {
      matchManagers: ['gomod'],
      matchPackageNames: [
        'github.com/gardener/gardener',
        'github.com/gardener/gardener/**',
      ],
      groupName: 'gardener-dependencies',
      prTitle: 'Update gardener/gardener to {{newVersion}}',
    },
    // Disable ignored packages from dependabot ignore list
    {
      matchManagers: ['gomod'],
      matchPackageNames: [
        'k8s.io/**',
        'sigs.k8s.io/**',
        'github.com/gardener/etcd-druid/**',
        'github.com/prometheus-operator/**',
      ],
      enabled: false,
    },
    // Disable Go toolchain updates in go.mod — managed via Dockerfile instead
    {
      matchManagers: ['gomod'],
      matchPackageNames: ['go'],
      enabled: false,
    },
  ],
}
